{
  "mcpServers": {
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.tavily.com/mcp/",
        "--header",
        "Authorization:Bearer ${MCP_TAVILY_API_KEY}"
      ],
      "env": {
        "TAVILY_API_KEY": "${MCP_TAVILY_API_KEY}"
      }
    }
  }
}

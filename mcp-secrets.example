# MCP-related environment variables (copy to .env.local and fill in)
# cp mcp-secrets.example .env.local
#
# Reference these from mcp-servers.json as ${VAR_NAME} in env blocks.

# Example: AWS profile/region for awslabs MCP servers
# AWS_PROFILE=your-profile
# AWS_REGION=us-east-1

# Example: API keys (never commit real values)
# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_TEAM_ID=Txxxxxxxx

# TAVILY_API_KEY=tvly-xxxx
# DD_API_KEY=xxxx
# DD_APPLICATION_KEY=xxxx

{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "python3 .cursor/hooks/generated_file_guard.py",
        "matcher": "Write|Edit",
        "failClosed": true,
        "timeout": 20
      }
    ],
    "postToolUse": [
      {
        "command": "python3 .cursor/hooks/auto_sync.py",
        "matcher": "Write|Edit",
        "timeout": 30
      }
    ]
  }
}
